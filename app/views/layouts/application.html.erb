<!DOCTYPE html>
<html lang="fr">
<head>
  <title><%= content_for?(:title) ? yield(:title) : "Otterly Web - Le web otterment bien pensé" %></title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= favicon_link_tag "favicon.png" %>

  <meta name="description" content="Otterly Web - Studio de développement web créatif à Bordeaux. Sites sur mesure, UX/UI, déploiement fiable et maintenance continue.">
  <meta property="og:title" content="Otterly Web - Le web otterment bien pensé">
  <meta property="og:description" content="Otterly Web - Studio de développement web créatif à Bordeaux. Sites sur mesure, UX/UI, déploiement fiable et maintenance continue.">
  <meta property="twitter:title" content="Otterly Web - Le web otterment bien pensé">
  <meta property="twitter:description" content="Otterly Web - Studio de développement web créatif à Bordeaux. Sites sur mesure, UX/UI, déploiement fiable et maintenance continue.">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="robots" content="index, follow">
  <meta property="og:image" content="https://www.otterly-web.fr/images/loutre-dev.png">
  <meta name="twitter:image" content="https://www.otterly-web.fr/images/loutre-dev.png">

  <!-- Icônes technos -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css">

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com" rel="preconnect">
  <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin="anonymous">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@100;200;300;400;500;600;700;800;900&family=Inconsolata:wght@400;700&family=Inter:wght@400;600&family=Anton+SC&family=Fira+Code:wght@400;500;700&display=block" rel="stylesheet">

  <style>
    * {
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
  </style>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Otterly Web",
    "url": "https://otterly-web.fr",
    "logo": "https://otterly-web.fr/images/logo.png",
    "sameAs": [
      "https://www.linkedin.com/in/julie-simon1302/",
      "https://github.com/JuS1302",
      "https://www.malt.fr/profile/juliesimon4?overview"
    ],
    "description": "Studio de développement web créatif à Bordeaux. Sites sur mesure, UX/UI, déploiement fiable et maintenance continue."
  }
  </script>

  <%= yield :head %>

  <%= stylesheet_link_tag "normalize", "web", "otterly-web.css?ts=#{Time.now.to_i}", "animations", media: "all" %>
  <%= javascript_include_tag "animations", defer: true %>
</head>

<body class="body">
  <div class="page-wrapper">
    <%= yield %>
  </div>
</body>
</html>

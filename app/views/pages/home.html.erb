<%# CSS pour le menu déroulant mobile %>

      <style>
        /* Masquer la case à cocher mais la garder accessible */
        .menu-toggle-input {
          position: absolute;
          opacity: 0;
          pointer-events: none;
        }

        /* Style pour la conteneur du menu mobile */
        .mobile-menu-container {
          display: none; /* Par défaut caché sur desktop */
        }

        /* Style pour l'icône du menu burger */
        .menu-toggle-label {
          cursor: pointer;
          display: block;
          width: 30px;
          height: 20px;
          position: relative;
          z-index: 1001;
        }

        .menu-toggle-icon {
          width: 100%;
          height: 100%;
          position: relative;
        }

        /* Traits du menu en mode clair */
        .menu-toggle-line.light {
          background-color: #0e1011; /* Couleur sombre pour mode clair */
          display: block;
          width: 100%;
          height: 2px;
          position: absolute;
          transition: transform 0.3s ease, opacity 0.3s ease;
        }

        /* Traits du menu en mode sombre */
        .menu-toggle-line.dark {
          background-color: #ffffff; /* Couleur blanche pour mode sombre */
          display: block;
          width: 100%;
          height: 2px;
          position: absolute;
          transition: transform 0.3s ease, opacity 0.3s ease;
        }

        .menu-toggle-line:first-child {
          top: 0;
        }

        .menu-toggle-line:last-child {
          bottom: 0;
        }

        /* Le menu lui-même - mode clair */
        .mobile-menu-new.light {
          position: fixed;
          top: 0;
          left: 0;
          width: 100%;
          height: 100vh;
          background-color: #ffffff; /* Fond blanc pour mode clair */
          z-index: 1000;
          transform: translateY(-100%);
          transition: transform 0.5s ease;
          display: flex;
          align-items: center;
          justify-content: center;
        }

        /* Le menu lui-même - mode sombre */
        .mobile-menu-new.dark {
          position: fixed;
          top: 0;
          left: 0;
          width: 100%;
          height: 100vh;
          background-color: #121212; /* Fond noir pour mode sombre */
          z-index: 1000;
          transform: translateY(-100%);
          transition: transform 0.5s ease;
          display: flex;
          align-items: center;
          justify-content: center;
        }

        .mobile-menu-list {
          list-style: none;
          padding: 0;
          margin: 0;
          text-align: center;
        }

        .mobile-menu-list li {
          margin: 30px 0;
        }

        .mobile-menu-list a {
          font-family: var(--global--body-font-family);
          color: var(--global-colors--text-default);
          font-size: 2rem;
          font-weight: 600;
          text-decoration: none;
          display: block;
          transition: color 0.3s ease;
        }

        /* Couleur au survol - mode clair */
        .mobile-menu-new.light .mobile-menu-list a:hover {
          color: #666;
        }

        /* Couleur au survol - mode sombre */
        .mobile-menu-new.dark .mobile-menu-list a:hover {
          color: #aaa;
        }

        /* Animation lorsque le menu est ouvert - Mode clair */
        .menu-toggle-input:checked ~ .mobile-menu-container .mobile-menu-new.light {
          transform: translateY(0);
        }

        /* Animation lorsque le menu est ouvert - Mode sombre */
        .menu-toggle-input:checked ~ .mobile-menu-container .mobile-menu-new.dark {
          transform: translateY(0);
        }

        /* Animation des lignes du burger en X - Mode clair */
        .menu-toggle-input:checked ~ .mobile-menu-container .light-mode .menu-toggle-line.light:first-child {
          transform: translateY(9px) rotate(45deg);
        }

        .menu-toggle-input:checked ~ .mobile-menu-container .light-mode .menu-toggle-line.light:last-child {
          transform: translateY(-9px) rotate(-45deg);
        }

        /* Animation des lignes du burger en X - Mode sombre */
        .menu-toggle-input:checked ~ .mobile-menu-container .dark-mode .menu-toggle-line.dark:first-child {
          transform: translateY(9px) rotate(45deg);
        }

        .menu-toggle-input:checked ~ .mobile-menu-container .dark-mode .menu-toggle-line.dark:last-child {
          transform: translateY(-9px) rotate(-45deg);
        }

        /* Afficher le menu mobile uniquement sur les petits écrans */
        @media screen and (max-width: 767px) {
          .mobile-menu-container {
            display: block;
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 1000;
          }

          /* Ajustement pour le bouton "On échange ?" */
          .navbar-right {
            margin-right: 50px; /* Espace pour le menu burger */
          }

          .mobile-menu-toggle {
            display: none !important;
          }

          .mobile-menu {
            display: none !important;
          }
        }
      </style>



<%# /* JS pour menu déroulant mobile */ %>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        // Sélectionner tous les liens du menu
        var menuLinks = document.querySelectorAll('.mobile-menu-list a');
        var menuToggle = document.getElementById('menu-toggle');

        // Ajouter un écouteur d'événement à chaque lien
        menuLinks.forEach(function(link) {
          link.addEventListener('click', function(e) {
            // Empêcher le comportement par défaut du lien pour contrôler la navigation
            e.preventDefault();

            // Récupérer l'ID de la section cible
            var targetId = link.getAttribute('href');

            // Fermer le menu en décochant la case à cocher
            menuToggle.checked = false;

            // Attendre que l'animation de fermeture soit terminée avant de faire défiler
            setTimeout(function() {
              // Trouver l'élément correspondant
              var targetElement = document.querySelector(targetId);

              // Faire défiler jusqu'à la section cible
              if (targetElement) {
                // Calculer la position de la section cible
                var offset = targetElement.getBoundingClientRect().top + window.pageYOffset;

                // Faire défiler la page vers la section cible
                window.scrollTo({
                  top: offset,
                  behavior: 'smooth'
                });
              }
            }, 300); // Délai correspondant à l'animation du menu
          });
        });
      });
    </script>

    <%# /* JS pour liens footer : renvoient bien en haut de chaque section */ %>
    <script>
          document.addEventListener('DOMContentLoaded', function() {
      // Attendre que tout soit complètement chargé
      setTimeout(function() {

        function scrollToSectionTop(targetId) {
          var targetElement = document.querySelector(targetId);
          if (targetElement) {
            // Méthode alternative : utiliser offsetTop
            var elementTop = targetElement.offsetTop;

            // Animation plus lente et plus fluide
            var startPosition = window.pageYOffset;
            var distance = elementTop - startPosition;
            var duration = Math.max(800, Math.abs(distance) * 0.5); // Durée minimum 800ms
            var startTime = null;

            function animateScroll(currentTime) {
              if (startTime === null) startTime = currentTime;
              var timeElapsed = currentTime - startTime;
              var progress = Math.min(timeElapsed / duration, 1);

              // Fonction d'easing pour une animation plus douce
              var easeInOutQuad = progress < 0.5
                ? 2 * progress * progress
                : 1 - Math.pow(-2 * progress + 2, 2) / 2;

              var currentPosition = startPosition + (distance * easeInOutQuad);
              window.scrollTo(0, currentPosition);

              if (progress < 1) {
                requestAnimationFrame(animateScroll);
              }
            }

            requestAnimationFrame(animateScroll);
          }
        }

        // Appliquer notre propre comportement à tous les liens internes
        var allInternalLinks = document.querySelectorAll('a[href^="#"]:not([href="#"])');

        allInternalLinks.forEach(function(link) {
          if (!link.closest('.mobile-menu-list')) {
            link.addEventListener('click', function(e) {
              e.preventDefault();
              e.stopImmediatePropagation();

              var targetId = link.getAttribute('href');
              console.log('Scrolling to:', targetId); // Pour déboguer
              scrollToSectionTop(targetId);
            });
          }
        });

        // Script mobile inchangé
        var menuLinks = document.querySelectorAll('.mobile-menu-list a');
        var menuToggle = document.getElementById('menu-toggle');

        menuLinks.forEach(function(link) {
          link.addEventListener('click', function(e) {
            e.preventDefault();
            var targetId = link.getAttribute('href');
            menuToggle.checked = false;

            setTimeout(function() {
              scrollToSectionTop(targetId);
            }, 300);
          });
        });

      }, 100); // Petit délai pour s'assurer que tout est chargé
    });
    </script>

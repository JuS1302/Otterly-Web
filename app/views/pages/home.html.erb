    <main class="main-wrapper">
      <section class="section-home-hero">
        <div class="home-hero-grid">
            <%= image_tag "Loutre-code.jpg",
              loading: "lazy",
              height: 70,
              alt: "Loutre développeuse Otterly Web",
              class: "home-hero-image" %>
